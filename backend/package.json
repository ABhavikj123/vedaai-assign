{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "Backend API for VedaAI AI Assessment Creator",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/assignmentWorker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/workers/assignmentWorker.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.47.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.2",
    "socket.io": "^4.8.1",
    "svg-to-pdfkit": "^0.1.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.13.5",
    "@types/svg-to-pdfkit": "^0.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
